{
  "name": "renderly",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "test": "pnpm -r --sort test",
    "test:coverage": "pnpm -r --sort test:coverage",
    "typecheck": "pnpm -r --sort build && pnpm -r typecheck",
    "check:publishability": "node scripts/check-publishability.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.5"
  }
}
